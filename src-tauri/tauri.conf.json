{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SmartDocs",
  "version": "0.1.0",
  "identifier": "com.smartdocs.desktop",
  "build": {
    "frontendDist": "../desktop/splash"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; connect-src 'none'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb"],
    "category": "Productivity",
    "shortDescription": "Offline-first document AI platform",
    "longDescription": "SmartDocs desktop: OCR, translation, summarization, retrieval and agent workflows running fully local. The UI is a native WebView backed by a bundled Python sidecar bound to 127.0.0.1.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../desktop/sidecar/dist/smartdocs-sidecar/": "sidecar/"
    }
  }
}
