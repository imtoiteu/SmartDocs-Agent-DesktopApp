<mxfile host="app.diagrams.net" type="device"><diagram name="D1 · Kiến trúc tổng thể SmartDocs DesktopApp" id="desktop-overall-architecture"><mxGraphModel dx="900" dy="600" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1360" pageHeight="770" math="0" shadow="0"><root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="title" value="D1 · Kiến trúc tổng thể SmartDocs DesktopApp" style="text;html=1;fontSize=20;fontStyle=1;verticalAlign=middle;align=left;fontColor=#10202E;" vertex="1" parent="1"><mxGeometry x="40" y="14" width="1280" height="32" as="geometry"/></mxCell><mxCell id="SHELL" value="Tauri Shell (Rust — src-tauri) — cửa sổ gốc, vòng đời tiến trình" style="swimlane;rounded=1;arcSize=4;startSize=34;html=1;whiteSpace=wrap;fontSize=14;fontStyle=1;fillColor=#F5F5F5;strokeColor=#999999;swimlaneFillColor=#FBFBFB;fontColor=#10202E;verticalAlign=middle;align=left;spacingLeft=8;" vertex="1" parent="1"><mxGeometry x="40" y="64" width="1280" height="100" as="geometry"/></mxCell><mxCell id="UI" value="WebView — Giao diện DesktopApp (GIỮ NGUYÊN trong mọi chế độ runtime)" style="swimlane;rounded=1;arcSize=4;startSize=34;html=1;whiteSpace=wrap;fontSize=14;fontStyle=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;swimlaneFillColor=#F0F6FD;fontColor=#10202E;verticalAlign=middle;align=left;spacingLeft=8;" vertex="1" parent="1"><mxGeometry x="40" y="186" width="1280" height="108" as="geometry"/></mxCell><mxCell id="GW" value="UI Gateway — desktop_gateway.py · origin DUY NHẤT của WebView: http://127.0.0.1:&lt;cổng&gt;" style="swimlane;rounded=1;arcSize=4;startSize=34;html=1;whiteSpace=wrap;fontSize=14;fontStyle=1;fillColor=#E1D5E7;strokeColor=#9673A6;swimlaneFillColor=#F3EFF5;fontColor=#10202E;verticalAlign=middle;align=left;spacingLeft=8;" vertex="1" parent="1"><mxGeometry x="40" y="318" width="1280" height="100" as="geometry"/></mxCell><mxCell id="RT" value="Backend runtime — chọn 1 trong 3 chế độ (runtime.json)" sty